    <diagram name="Photon Architecture" id="photon-arch">
        <mxGraphModel dx="1456" dy="1094" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title" value="Photon — Distributed Stream Joiner (CSCI 652)" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="550" y="10" width="600" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="kafka_clicks" value="Kafka topic&#xa;photon.clicks&#xa;(click events: id, hlc, query_id)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="370" y="280" width="160" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="dispatcher" value="Dispatcher&#xa;(Dispatcher.java)&#xa;&#xa;• Kafka consumer&#xa;• Pre-check IdRegistry (skip 95%)&#xa;• Dispatch via gRPC&#xa;• DelayQueue retry (100ms→30s)&#xa;• Metrics on :9094" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="330" y="80" width="240" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="joiner" value="Joiner  (gRPC server :9093)&#xa;(Joiner.java)&#xa;&#xa;5-step pipeline:&#xa;1. Throttle check&#xa;2. EventStore lookup (query)&#xa;3. JoinAdapter combine&#xa;4. IdRegistry insert (exactly-once)&#xa;5. Kafka write" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="600" y="80" width="260" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="idregistry" value="IdRegistryServer&#xa;(IDRegistryServer.java)&#xa;gRPC :9091&#xa;&#xa;Exactly-once gate via&#xa;etcd conditional txn&#xa;(IF absent THEN PUT w/ lease)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="900" y="80" width="220" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="etcd" value="etcd 3.5&#xa;(:2379)&#xa;atomic register" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1200" y="100" width="140" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="tiered" value="TieredEventStore (in-process)&#xa;L1: CacheEventStore  →  L2: LogsEventStore&#xa;backfill on miss; durable writes to both" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="560" y="370" width="340" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="redis" value="Redis 7&#xa;(:6379)&#xa;L1 cache&#xa;TTL 300s&#xa;key: photon:q:{id}" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="400" y="520" width="160" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="hbase" value="HBase 2.5&#xa;(:16000/16010/16020)&#xa;L2 durable store&#xa;table: photon_queries&#xa;cf: e (SNAPPY)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="870" y="500" width="160" height="140" as="geometry"/>
                </mxCell>
