                </mxCell>
                <mxCell id="cap" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;Figure 2.&amp;nbsp;&lt;/font&gt;&lt;div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;color: rgb(63, 63, 63); font-size: 18px; background-color: transparent;&quot;&gt;The IdRegistry. Each Insert is realised as a sin&lt;/span&gt;&lt;span style=&quot;font-size: 18px; background-color: transparent; color: rgb(63, 63, 63);&quot;&gt;gle etcd transaction that succeeds only&lt;/span&gt;&lt;span style=&quot;font-size: 18px; background-color: transparent; color: rgb(63, 63, 63);&quot;&gt;&amp;nbsp;when the&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(63, 63, 63); background-color: transparent; font-size: 18px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: rgb(63, 63, 63);&quot;&gt;event-id&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent; font-size: 18px;&quot;&gt;key is absent (Version=0). Linearizability comes from Raft quorum commit; idempotency comes&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: rgb(63, 63, 63); font-size: 18px;&quot;&gt;from the owner-token (host:pid:startMs); garbage collection comes from the etcd lease attached to the Put.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;fontSize=10;fontStyle=2;" parent="1" vertex="1">
                    <mxGeometry x="40" y="570" width="850" height="60" as="geometry"/>
                </mxCell>
