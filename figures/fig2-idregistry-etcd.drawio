                <mxCell id="resp" value="Insert outcomes&#xa;&#xa;SUCCESS         — first writer wins (Put committed)&#xa;ALREADY_EXISTS  — key present; existing owner returned&#xa;TOO_OLD         — HLC age &gt; window (rejected pre-Txn)&#xa;RETRY           — etcd unavailable / lease lost" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;fontFamily=Courier New;align=left;spacingLeft=10;" parent="1" vertex="1">
